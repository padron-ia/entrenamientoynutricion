# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                                                                              ║
# ║   CRM COACHING PRO - CONFIGURACION DE ENTORNO                                ║
# ║                                                                              ║
# ║   Copia este archivo como .env.local y rellena tus credenciales              ║
# ║   Comando: cp .env.example .env.local                                        ║
# ║                                                                              ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ==============================================================================
# SUPABASE (OBLIGATORIO)
# ==============================================================================
# Obtener en: https://supabase.com > Tu Proyecto > Settings > API
#
# Project URL - La URL de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon Key - La clave publica (anon) de tu proyecto
# IMPORTANTE: Esta clave es segura para el frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ==============================================================================
# ENTORNO (OPCIONAL)
# ==============================================================================
# development = Modo desarrollo con datos de prueba
# production = Modo produccion
VITE_ENV=development

# Captcha Turnstile (Cloudflare) para formulario publico de leads
VITE_TURNSTILE_SITE_KEY=


# ==============================================================================
# INTELIGENCIA ARTIFICIAL (OPCIONAL)
# ==============================================================================
# API Key de Google Gemini para funciones de IA
# Obtener en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=


# ==============================================================================
# AUTOMATIZACIONES (OPCIONAL)
# ==============================================================================
# URL del webhook para notificar nuevas ventas (N8N, Make, Zapier, etc.)
VITE_WEBHOOK_NEW_SALE=

# URL del webhook para notificar onboarding completado
VITE_WEBHOOK_ONBOARDING=


# ==============================================================================
# PERSONALIZACION (OPCIONAL)
# ==============================================================================
# Nombre de tu negocio (aparece en el titulo de la pagina)
VITE_BUSINESS_NAME=Mi Academia de Coaching

# URL de tu logo (si no usas el archivo public/logo.png)
VITE_LOGO_URL=


# ==============================================================================
# SCRIPTS DE SINCRONIZACION (archivo .env separado)
# ==============================================================================
# Para los scripts Node.js (sync_notion_leads.js, etc.)
# Crear archivo .env en la raiz del proyecto con estas variables:

# NOTION_TOKEN=ntn_...tu_token_de_notion
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_ANON_KEY=eyJ...tu_anon_key
# SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key (SOLO para scripts admin)


# ==============================================================================
# NOTAS IMPORTANTES DE SEGURIDAD
# ==============================================================================
#
# 1. NUNCA subas .env o .env.local a Git (ya estan en .gitignore)
#
# 2. NUNCA hardcodees claves API en el codigo fuente
#
# 3. Las variables VITE_* son publicas (visibles en el navegador)
#    - Solo usar ANON KEY, nunca SERVICE ROLE KEY
#
# 4. Para GitHub Pages: Configura secrets en GitHub Actions
#    Settings > Secrets and variables > Actions
#
# 5. ROTA las claves inmediatamente si sospechas que fueron expuestas
#
# ==============================================================================
